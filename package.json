{
  "name": "unleash-fullstack-demo-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently 'npm:dev:backend' 'npm:dev:frontend'",
    "dev:frontend": "vite",
    "dev:backend": "tsx watch backend/src/index.ts",
    "check": "tsc && tsc -p backend --noEmit",
    "build": "vite build",
    "lint": "eslint src backend/src --max-warnings 0",
    "preview": "vite preview",
    "start": "npm run build && npm run start:backend",
    "start:backend": "tsx backend/src/index.ts",
    "test-chat": "node backend/test-chat-api.js",
    "test-metrics": "node backend/test-metrics.js",
    "e2e": "npx playwright test --ui"
  },
  "dependencies": {
    "@iconify/react": "^4.1.0",
    "@unleash/proxy-client-react": "^6.0.0",
    "bowser": "^2.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "tsx": "4.19.4",
    "unleash-proxy-client": "^3.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.30",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react-swc": "^3.0.0",
    "autoprefixer": "^10.4.14",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.0.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^6.4.3"
  },
  "workspaces": [
    "backend"
  ],
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.15.1"
}
