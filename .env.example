# Copy this file to `.env` and fill in the values for your Unleash instance:
#
#   cp .env.example .env
#
# The backend loads this file natively on startup (backend/src/loadEnv.ts);
# Vite reads the VITE_* values from the same file. Variables already set in
# the process environment (e.g. the Render dashboard) take precedence.

# --- Unleash backend (server-side) SDK — required ---
# Server API base URL, ends with /api/
UNLEASH_URL=https://<your-instance>/api/
# Backend (client) token for the project/environment, format: project:environment.hash
UNLEASH_API_KEY=<client-token>

# --- Unleash frontend SDK (read by Vite at dev/build time) — required ---
# Frontend API base URL, ends with /api/frontend
VITE_UNLEASH_FRONTEND_API_URL=https://<your-instance>/api/frontend
# Frontend token for the project/environment
VITE_UNLEASH_FRONTEND_API_KEY=<frontend-token>

# --- Optional ---
# Display-only override for the environment ribbon and header text.
# When unset, the environment name is parsed from the frontend token.
# VITE_ENVIRONMENT_LABEL=development
# "Open Unleash" link target for the project shown in the header.
# VITE_UNLEASH_PROJECT_URL=https://app.unleash-hosted.com/demo/projects/unleash-fullstack-demo-app

# Backend runtime mode: development | production
NODE_ENV=development
# Backend HTTP port (default: 3000)
# PORT=3000
